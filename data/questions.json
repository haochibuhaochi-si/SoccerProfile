  "literacy": [
    {
      "id": "K1",
      "text": "当对手在后场组织进攻时，高位逼抢体系（如瓜迪奥拉的曼城或克洛普的利物浦）通常会有意诱导对方将球传到边线或某个特定区域，然后进行围剿。这个战术区域的术语通常被称为？",
      "options": [
        {
          "key": "A",
          "label": "压迫盲区（Pressing Blind Spot）",
          "tags": []
        },
        {
          "key": "B",
          "label": "战术甜区 / 强制区域（The Forcing Zone / Red Zone）",
          "tags": []
        },
        {
          "key": "C",
          "label": "安全回传走廊（Safety Corridor）",
          "tags": []
        },
        {
          "key": "D",
          "label": "控球陷阱（Possession Trap）",
          "tags": []
        }
      ],
      "type": "radio",
      "correctKey": "B"
    },
    {
      "id": "K2",
      "text": "当防守队员逼近时，你用脚内侧将球向后一磕，随即转身摆脱，这一动作通常被称为？",
      "options": [
        {
          "key": "A",
          "label": "马赛回旋",
          "tags": []
        },
        {
          "key": "B",
          "label": "克鲁伊夫转身",
          "tags": []
        },
        {
          "key": "C",
          "label": "牛尾巴过人",
          "tags": []
        },
        {
          "key": "D",
          "label": "油炸丸子",
          "tags": []
        }
      ],
      "type": "radio",
      "correctKey": "B"
    },
    {
      "id": "K3",
      "text": "当对方边后卫在边线附近拿球时，我方压迫小组最有效的包夹策略是？",
      "options": [
        {
          "key": "A",
          "label": "两人直接冲上去抢球，容易被过掉",
          "tags": []
        },
        {
          "key": "B",
          "label": "封死边路外线，迫使持球人向肋部（Half-space）转身，利用边线作为天然围墙进行合围",
          "tags": []
        },
        {
          "key": "C",
          "label": "一人上前抢球，另一人留在中路保护（防守脱节）",
          "tags": []
        },
        {
          "key": "D",
          "label": "直接战术犯规",
          "tags": []
        }
      ],
      "type": "radio",
      "correctKey": "B"
    },
    {
      "id": "K4",
      "text": "阿尔特塔的阿森纳或瓜迪奥拉的曼城经常使用一名中后卫（通常是斯通斯或萨利巴）拉边，从而将防线变为临时的“2-3-5”进攻形态。这一战术动作的主要目的是？",
      "options": [
        {
          "key": "A",
          "label": "增加防守厚度",
          "tags": []
        },
        {
          "key": "B",
          "label": "将对方边锋拉离中路，并利用后腰（CDM）填补防线空缺，从而制造局部人数优势",
          "tags": []
        },
        {
          "key": "C",
          "label": "让门将更安全地开球",
          "tags": []
        },
        {
          "key": "D",
          "label": "专门破解越位陷阱",
          "tags": []
        }
      ],
      "type": "radio",
      "correctKey": "B"
    },
    {
      "id": "K5",
      "text": "在现代足球的“门将参与后场出球”体系中，门将不仅仅是防守者，更是“清道夫门将”（Sweeper-Keeper）。当对方前锋实施压迫时，门将最理想的出球路线通常是？",
      "options": [
        {
          "key": "A",
          "label": "大脚开向前场寻找高中锋",
          "tags": []
        },
        {
          "key": "B",
          "label": "短传给回撤的中后卫，由中后卫长传",
          "tags": []
        },
        {
          "key": "C",
          "label": "斜长传转移至处于开阔地的边后卫/边翼卫，避开对方压迫密集区",
          "tags": []
        },
        {
          "key": "D",
          "label": "在禁区内带球直到找到空档",
          "tags": []
        }
      ],
      "type": "radio",
      "correctKey": "C"
    }
  ]
}